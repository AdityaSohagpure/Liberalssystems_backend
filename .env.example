# Gateway configuration
PORT=5000
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Service URLs
USER_SERVICE_URL=http://localhost:5001
CATALOG_SERVICE_URL=http://localhost:5002
ORDER_SERVICE_URL=http://localhost:5003
PAYMENT_SERVICE_URL=http://localhost:5004
CUSTOM_REQUEST_SERVICE_URL=http://localhost:5005

# Database URLs (used by individual microservice Prisma configurations)
USER_DB_URL=postgresql://postgres:password@localhost:5432/user_db?schema=public
CATALOG_DB_URL=postgresql://postgres:password@localhost:5432/catalog_db?schema=public
ORDER_DB_URL=postgresql://postgres:password@localhost:5432/order_db?schema=public
PAYMENT_DB_URL=postgresql://postgres:password@localhost:5432/payment_db?schema=public
CUSTOM_DB_URL=postgresql://postgres:password@localhost:5432/custom_db?schema=public
